generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Papel {
  id_papel   String    @id @default(uuid()) @db.Uuid
  nome_papel String    @unique @db.VarChar(50)
  usuarios   Usuario[]

  @@map("papeis")
}

model Equipe {
  id_equipe   String    @id @default(uuid()) @db.Uuid
  nome_equipe String    @db.VarChar(100)
  usuarios    Usuario[]

  @@map("equipes")
}

model Loja {
  id_loja   String @id @default(uuid()) @db.Uuid
  nome_loja String @db.VarChar(100)
  leads     Lead[]

  @@map("lojas")
}

model Usuario {
  id_usuario           String   @id @default(uuid()) @db.Uuid
  nome_usuario         String   @db.VarChar(150)
  email_usuario        String   @unique @db.VarChar(150)
  senha_hash_usuario   String   @db.VarChar(255)
  id_papel             String   @db.Uuid
  id_equipe            String?  @db.Uuid
  data_criacao_usuario DateTime @default(now()) @db.Timestamp()

  // Relacionamentos
  papel                Papel                  @relation(fields: [id_papel], references: [id_papel])
  equipe               Equipe?                @relation(fields: [id_equipe], references: [id_equipe])
  leads                Lead[]                 // Leads que o atendente gerencia
  historicos           HistoricoNegociacao[]  // Histórico de alterações feitas por este usuário
  logs                 LogOperacao[]          // Logs gerados por este usuário (RF07)

  @@map("usuarios")
}

model Cliente {
  id_cliente       String @id @default(uuid()) @db.Uuid
  nome_cliente     String @db.VarChar(150)
  telefone_cliente String @db.VarChar(20)
  email_cliente    String @unique @db.VarChar(150)
  leads            Lead[]

  @@map("clientes")
}

model Origem {
  id_origem   String @id @default(uuid()) @db.Uuid
  nome_origem String @unique @db.VarChar(50)
  leads       Lead[]

  @@map("origens")
}

model Status {
  id_status   String        @id @default(uuid()) @db.Uuid
  nome_status String        @unique @db.VarChar(50)
  leads       Lead[]
  negociacoes Negociacao[]

  @@map("status")
}

model Estagio {
  id_estagio   String        @id @default(uuid()) @db.Uuid
  nome_estagio String        @unique @db.VarChar(50)
  negociacoes  Negociacao[]

  @@map("estagios")
}

model Lead {
  id_lead               String   @id @default(uuid()) @db.Uuid
  id_cliente            String   @db.Uuid
  id_usuario            String   @db.Uuid // Atendente responsável (RF02)
  id_loja               String   @db.Uuid
  id_origem             String   @db.Uuid
  id_status             String   @db.Uuid
  data_criacao_lead     DateTime @default(now()) @db.Timestamp()
  data_atualizacao_lead DateTime @default(now()) @updatedAt @db.Timestamp()

  // Relacionamentos
  cliente               Cliente      @relation(fields: [id_cliente], references: [id_cliente])
  usuario               Usuario      @relation(fields: [id_usuario], references: [id_usuario])
  loja                  Loja         @relation(fields: [id_loja], references: [id_loja])
  origem                Origem       @relation(fields: [id_origem], references: [id_origem])
  status                Status       @relation(fields: [id_status], references: [id_status])
  negociacoes           Negociacao[]

  @@map("leads")
}

model Negociacao {
  id_negociacao              String   @id @default(uuid()) @db.Uuid
  id_lead                    String   @db.Uuid
  estado_abertura_negociacao Boolean  @default(true)
  importancia_negociacao     String   @db.VarChar(20) // FRIO, MORNO, QUENTE
  data_criacao_negociacao    DateTime @default(now()) @db.Timestamp()
  id_estagio                 String   @db.Uuid
  id_status                  String   @db.Uuid

  // Relacionamentos
  lead                       Lead                  @relation(fields: [id_lead], references: [id_lead])
  estagio                    Estagio               @relation(fields: [id_estagio], references: [id_estagio])
  status                     Status                @relation(fields: [id_status], references: [id_status])
  historicos                 HistoricoNegociacao[] // RF03 - Histórico de mudanças

  @@map("negociacoes")
}

model HistoricoNegociacao {
  id_historico             String   @id @default(uuid()) @db.Uuid
  id_negociacao            String   @db.Uuid
  id_usuario               String   @db.Uuid // Quem fez a alteração
  detalhe_alteracao_historico String
  data_alteracao_historico DateTime @default(now()) @db.Timestamp()

  negociacao               Negociacao @relation(fields: [id_negociacao], references: [id_negociacao])
  usuario                  Usuario    @relation(fields: [id_usuario], references: [id_usuario])

  @@map("historicos_negociacoes")
}

model LogOperacao {
  id_log                String   @id @default(uuid()) @db.Uuid
  id_usuario            String   @db.Uuid
  acao_log              String   @db.VarChar(50)
  tabela_afetada_log    String   @db.VarChar(50)
  id_registro_afetado   String?  @db.Uuid
  data_hora_log         DateTime @default(now()) @db.Timestamp()

  usuario               Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("logs_operacoes")
}